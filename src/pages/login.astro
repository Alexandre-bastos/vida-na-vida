---
import '../styles/global.css';
import { getSession } from 'auth-astro/server';

const session = await getSession(Astro.request);
if (session) return Astro.redirect('/');
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Login - Vida na Vida" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title>Entrar | Vida na Vida</title>
    <style>
      body {
        font-family: 'Outfit', sans-serif;
      }
      .glass-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }
      .loading {
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .loading::after {
        content: '';
        width: 1em;
        height: 1em;
        margin-left: 0.5em;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s ease-in-out infinite;
      }
      @keyframes spin {
        to { transform: rotate(360deg); }
      }
    </style>
  </head>
  <body class="bg-brand-bg antialiased min-h-screen flex flex-col items-center justify-center p-4 relative overflow-hidden">

    <!-- Efeito de fundo Premium -->
    <div class="absolute top-0 left-0 w-full h-full -z-10">
      <div class="absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-brand-primary/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[50%] h-[50%] bg-brand-accent/10 rounded-full blur-[120px]"></div>
    </div>

    <div class="w-full max-w-sm glass-card rounded-[2.5rem] shadow-2xl border border-white/50 p-10 flex flex-col items-center text-center">
      <img src="/images/logo.png" alt="Vida na Vida" class="h-24 w-auto mb-8 drop-shadow-md" />

      <h1 class="text-3xl font-bold text-brand-dark mb-2 tracking-tight">Bem-vindo(a)</h1>
      <p class="text-gray-500 mb-8 text-sm px-4">
        Acesse o sistema de gestão de células da Comunidade Vida na Vida.
      </p>

      <!-- Login com Google -->
      <button id="login-google" class="w-full flex items-center justify-center gap-3 bg-white border border-gray-100 text-gray-700 font-semibold py-4 px-4 rounded-2xl shadow-sm hover:shadow-md hover:bg-gray-50 transition-all active:scale-[0.98] group">
        <svg class="w-5 h-5 transition-transform group-hover:scale-110" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <span class="text-sm">Entrar com Google</span>
      </button>

      <!-- Divisor -->
      <div class="w-full flex items-center my-8">
        <div class="flex-grow border-t border-gray-100"></div>
        <span class="px-4 text-[10px] text-gray-300 font-bold uppercase tracking-[0.2em]">ou e-mail</span>
        <div class="flex-grow border-t border-gray-100"></div>
      </div>

      <!-- Login com Credenciais -->
      <form id="login-credentials" class="w-full flex flex-col gap-5" method="post" novalidate>
        <div class="flex flex-col text-left gap-1.5">
          <label for="email" class="text-[11px] font-bold text-gray-400 uppercase tracking-wider ml-1">E-mail</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="exemplo@vida.com"
            class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-white/50 focus:bg-white focus:ring-4 focus:ring-brand-primary/10 focus:border-brand-primary focus:outline-none transition-all placeholder:text-gray-300 text-sm"
          />
          <span class="hidden text-xs text-red-500 mt-1" data-error="email"></span>
        </div>

        <div class="flex flex-col text-left gap-1.5">
          <label for="password" class="text-[11px] font-bold text-gray-400 uppercase tracking-wider ml-1">Senha</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            placeholder="••••••••"
            class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-white/50 focus:bg-white focus:ring-4 focus:ring-brand-primary/10 focus:border-brand-primary focus:outline-none transition-all placeholder:text-gray-300 text-sm"
          />
          <span class="hidden text-xs text-red-500 mt-1" data-error="password"></span>
        </div>

        <button
          type="button"
          id="login-submit"
          class="w-full bg-brand-primary text-white font-bold py-4 rounded-2xl hover:brightness-110 shadow-xl shadow-brand-primary/20 transition-all active:scale-[0.98] mt-2 text-sm">
          Entrar no Sistema
        </button>
      </form>
    </div>

    <p class="text-[11px] text-gray-400 mt-10 font-medium tracking-wide">© 2026 COMUNIDADE CRISTÃ VIDA NA VIDA</p>

    <!-- ==== SCRIPT (processado pelo Astro/Vite) ==== -->
    <script>
      import { signIn } from 'auth-astro/client';

      // ---------- Login com Google ----------
      document.getElementById('login-google')?.addEventListener('click', () => {
        signIn('google');
      });

      // ---------- Função de exibição de erro ----------
      function showError(fieldName, message) {
        const errorEl = document.querySelector(`[data-error="${fieldName}"]`);
        if (errorEl) {
          errorEl.textContent = message;
          errorEl.classList.remove('hidden');
        }
      }

      function clearErrors() {
        document.querySelectorAll('[data-error]').forEach(el => el.classList.add('hidden'));
      }

      // ---------- Login com Credenciais (disparado pelo botão ou Enter) ----------
      async function handleLogin() {
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;

        // Limpar erros anteriores
        clearErrors();

        // Validação
        let hasErrors = false;
        if (!email) {
          showError('email', 'E‑mail é obrigatório');
          hasErrors = true;
        } else if (!/^[^\@\s]+@[^\@\s]+\.[^\@\s]+$/.test(email)) {
          showError('email', 'E‑mail inválido');
          hasErrors = true;
        }
        if (!password) {
          showError('password', 'Senha é obrigatória');
          hasErrors = true;
        }
        if (hasErrors) return;

        const btn = document.getElementById('login-submit');
        try {
          if (btn) {
            btn.innerHTML = '<span class="loading">Autenticando...</span>';
            btn.disabled = true;
          }

          const result = await signIn('credentials', {
            email,
            password,
            redirect: false,
          });

          console.log("SIGN IN RESULT:", result);

          if (result?.error) {
            showError('password', 'E-mail ou senha incorretos');
          } else if (result?.url && !result.url.includes('/api/auth/')) {
            window.location.href = result.url;
          } else {
            window.location.href = '/';
          }
        } catch (error) {
          console.error(error);
          showError('password', 'Erro ao processar login. Tente novamente.');
        } finally {
          if (btn) {
            btn.innerHTML = 'Entrar no Sistema';
            btn.disabled = false;
          }
        }
      }

      // Botão Entrar
      document.getElementById('login-submit')?.addEventListener('click', handleLogin);

      // Suporte à tecla Enter nos campos
      ['email', 'password'].forEach(id => {
        document.getElementById(id)?.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') handleLogin();
        });
      });
    </script>
  </body>
</html>