---
import AppLayout from '../layouts/AppLayout.astro';
import { getSession } from 'auth-astro/server';
import prisma from '../lib/prisma';
import { Camera, Save, MapPin, User as UserIcon, CheckCircle, Shield } from 'lucide-react';
import fs from 'fs';
import path from 'path';
import bcrypt from 'bcryptjs';

const session = await getSession(Astro.request);
if (!session) return Astro.redirect('/login');

const userId = (session.user as any)?.id;
const user = await prisma.user.findUnique({
  where: { id: userId },
  include: {
    cellHistory: {
      where: { endDate: null },
      include: { cell: true }
    },
    _count: {
      select: { presences: { where: { isPresent: true } } }
    }
  }
});

if (!user) return Astro.redirect('/login');

let success = false;
let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const name = formData.get('name')?.toString();
  const gender = formData.get('gender')?.toString();
  const city = formData.get('city')?.toString();
  const neighborhood = formData.get('neighborhood')?.toString();
  
  // Upload Foto
  const imageFile = formData.get('image') as unknown as File;
  let image = user.image;

  if (imageFile && (imageFile as any).size > 0) {
    try {
      const { put } = await import('@vercel/blob');
      const blob = await put(`profiles/${userId}-${Date.now()}-${(imageFile as any).name}`, imageFile, {
        access: 'public',
      });
      image = blob.url;
    } catch (err) {
      console.error("Erro ao fazer upload para o Vercel Blob:", err);
      error = "Erro ao fazer upload da imagem. O Vercel Blob não está configurado corretamente.";
    }
  }

  const newPassword = formData.get('newPassword')?.toString();
  const confirmPassword = formData.get('confirmPassword')?.toString();
  
  let updateData: any = {
    name: name || user.name,
    gender: gender || user.gender,
    city: city || user.city,
    neighborhood: neighborhood || user.neighborhood,
    image
  };

  if (newPassword && newPassword === confirmPassword && newPassword.length >= 6) {
    updateData.password = bcrypt.hashSync(newPassword, 10);
  }

  await prisma.user.update({
    where: { id: userId },
    data: updateData
  });
  
  success = true;
  // Recarregar dados para exibição
  return Astro.redirect('/perfil?success=1');
}

const isSuccess = Astro.url.searchParams.get('success') === '1';
---

<AppLayout title="Meu Perfil">
  <div class="max-w-2xl mx-auto space-y-6">
    <header>
      <h1 class="text-2xl font-bold text-brand-dark">Meu Perfil</h1>
      <p class="text-sm text-gray-500 mt-1">Gerencie suas informações e personalização.</p>
    </header>

    {isSuccess && (
      <div class="bg-green-50 border border-green-100 text-green-800 p-4 rounded-2xl flex items-center gap-3 animate-in fade-in slide-in-from-top-2">
        <CheckCircle size={20} />
        <span class="text-sm font-bold">Perfil atualizado com sucesso!</span>
      </div>
    )}

    {error && (
      <div class="bg-red-50 border border-red-100 text-red-800 p-4 rounded-2xl flex items-center gap-3 animate-in fade-in slide-in-from-top-2">
        <span class="text-sm font-bold">{error}</span>
      </div>
    )}

    <form method="POST" enctype="multipart/form-data" class="space-y-6">
      <!-- Card Principal: Foto e Identidade -->
      <section class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 text-center space-y-6">
        <div class="relative w-32 h-32 mx-auto">
          <div class="w-full h-full rounded-full overflow-hidden border-4 border-brand-bg shadow-inner bg-gray-50 flex items-center justify-center">
            {user.image ? (
              <img id="preview" src={user.image} alt={user.name || ''} class="w-full h-full object-cover" />
            ) : (
              <UserIcon size={48} class="text-gray-300" />
            )}
          </div>
          <label class="absolute bottom-0 right-0 w-10 h-10 bg-brand-primary text-white rounded-full flex items-center justify-center shadow-lg cursor-pointer hover:scale-110 transition-transform">
            <Camera size={18} />
            <input type="file" name="image" accept="image/*" class="hidden" onchange="const reader = new FileReader(); reader.onload = (e) => document.getElementById('preview').src = e.target.result; reader.readAsDataURL(this.files[0])" />
          </label>
        </div>

        <div>
          <h2 class="text-xl font-black text-brand-dark">{user.name}</h2>
          <p class="text-xs font-bold text-brand-primary uppercase tracking-widest mt-1">{user.role}</p>
        </div>

        <div class="grid grid-cols-2 gap-4 pt-4 border-t border-gray-50">
          <div class="text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Célula Atual</p>
            <p class="text-sm font-bold text-gray-700 mt-1">{user.cellHistory[0]?.cell.name || 'Sem célula'}</p>
          </div>
          <div class="text-center">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Presenças</p>
            <p class="text-sm font-bold text-gray-700 mt-1">{user._count.presences} encontros</p>
          </div>
        </div>
      </section>

      <!-- Dados Pessoais -->
      <section class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 space-y-6">
        <h3 class="font-bold text-brand-dark flex items-center gap-2">
          <UserIcon size={18} class="text-brand-primary" />
          Informações Pessoais
        </h3>

        <div class="grid gap-4">
          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Nome Completo</label>
            <input type="text" name="name" value={user.name} class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Sexo</label>
              <select name="gender" class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white outline-none appearance-none">
                <option value="">Selecione</option>
                <option value="M" selected={user.gender === 'M'}>Masculino</option>
                <option value="F" selected={user.gender === 'F'}>Feminino</option>
              </select>
            </div>
            <div class="space-y-1.5">
              <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Município</label>
              <input type="text" name="city" value={user.city || ''} placeholder="Ex: Rio de Janeiro" class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
            </div>
          </div>

          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Bairro</label>
            <div class="relative">
              <MapPin size={16} class="absolute left-5 top-1/2 -translate-y-1/2 text-gray-400" />
              <input type="text" name="neighborhood" value={user.neighborhood || ''} placeholder="Ex: Copacabana" class="w-full pl-12 pr-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
            </div>
          </div>
        </div>
      </section>

      <!-- Alterar Senha -->
      <section class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-gray-100 space-y-6">
        <h3 class="font-bold text-brand-dark flex items-center gap-2">
          <Shield size={18} class="text-brand-accent" />
          Segurança e Senha
        </h3>
        
        <p class="text-[11px] text-gray-400">Preencha apenas se desejar alterar sua senha atual.</p>

        <div class="grid sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Nova Senha</label>
            <input type="password" name="newPassword" placeholder="Mínimo 6 caracteres" class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
          </div>
          <div class="space-y-1.5">
            <label class="text-[11px] font-bold text-gray-400 uppercase tracking-widest ml-1">Confirmar Senha</label>
            <input type="password" name="confirmPassword" placeholder="Repita a nova senha" class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-4 focus:ring-brand-primary/5 transition-all" />
          </div>
        </div>
      </section>

      <div class="flex gap-4">
        <a href="/" class="flex-1 px-6 py-4 rounded-2xl border border-gray-100 font-bold text-gray-400 text-center hover:bg-gray-50 transition-all">Voltar</a>
        <button type="submit" class="flex-1 px-6 py-4 rounded-2xl bg-brand-primary text-white font-bold hover:brightness-110 shadow-lg shadow-brand-primary/20 transition-all flex items-center justify-center gap-2">
          <Save size={18} />
          Salvar Alterações
        </button>
      </div>
    </form>
  </div>
</AppLayout>

